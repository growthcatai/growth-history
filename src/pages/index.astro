            authToggleLink.innerHTML = 'Already have an account? <span style="color: #8B5CF6; font-weight: 700;">Sign In</span>';
          } else {
            authModalTitle.textContent = "Sign in to your account";
            authModalSubtitle.textContent = "Enter your credentials to manage your trackers.";
            authDividerText.textContent = "or email signin";
            btnSubmitAuthText.textContent = "Sign In";
            authToggleLink.innerHTML = 'Don\'t have an account? <span style="color: #8B5CF6; font-weight: 700;">Sign Up</span>';
          }
        });
      }

      // SSO Action simulation (OAuth redirect triggers)
      async function triggerSSO(provider) {
        try {
          await authClient.signIn.social({
            provider: provider,
            callbackURL: window.location.origin
          });
        } catch (e) {
          console.error("SSO failed:", e);
          alert(`SSO auth failed. Please try custom Email Signup.`);
        }
      }

      const btnGoogle = document.getElementById('btn-sso-google');
      if (btnGoogle) {
        btnGoogle.onclick = () => triggerSSO('google');
      }

      const btnFacebook = document.getElementById('btn-sso-facebook');
      if (btnFacebook) {
        btnFacebook.onclick = () => triggerSSO('facebook');
      }

      // Email Signup/Signin Form Submission
      const signupForm = document.getElementById('signup-form');
      const signupSubmit = document.getElementById('btn-submit-signup');
      if (signupForm && signupSubmit) {
        signupForm.addEventListener('submit', async (e) => {
          e.preventDefault();
          const email = document.getElementById('signup-email').value.trim();
          const password = document.getElementById('signup-password').value;

          const originalContent = signupSubmit.innerHTML;
          signupSubmit.setAttribute('disabled', 'true');

          if (isSignUpMode) {
            signupSubmit.innerHTML = `
              <svg class="spinner" viewBox="0 0 50 50" style="width:18px; height:18px; animation:rotate 2s linear infinite; margin-right:8px; display:inline-block; vertical-align:middle;">
                <circle class="path" cx="25" cy="25" r="20" fill="none" stroke-width="5" stroke="#ffffff" stroke-linecap="round" style="stroke-dasharray:90,150; stroke-dashoffset:0;"></circle>
              </svg>
              <span>Creating Account...</span>
            `;

            const { data, error } = await authClient.signUp.email({
              email,
              password,
              name: email.split('@')[0]
            });

            signupSubmit.innerHTML = originalContent;
            signupSubmit.removeAttribute('disabled');

            if (error) {
              alert(error.message || "Sign up failed.");
            } else {
              await checkSession();
              showStep(stepSetup);
            }
          } else {
            signupSubmit.innerHTML = `
              <svg class="spinner" viewBox="0 0 50 50" style="width:18px; height:18px; animation:rotate 2s linear infinite; margin-right:8px; display:inline-block; vertical-align:middle;">
                <circle class="path" cx="25" cy="25" r="20" fill="none" stroke-width="5" stroke="#ffffff" stroke-linecap="round" style="stroke-dasharray:90,150; stroke-dashoffset:0;"></circle>
              </svg>
              <span>Signing In...</span>
            `;

            const { data, error } = await authClient.signIn.email({
              email,
              password
            });

            signupSubmit.innerHTML = originalContent;
            signupSubmit.removeAttribute('disabled');

            if (error) {
              alert(error.message || "Sign in failed.");
            } else {
              await checkSession();
              closeModal();
            }
          }
        });
      }

      // Automatically sync name input to slug input
      const setupName = document.getElementById('setup-name');
      const setupSlug = document.getElementById('setup-slug');
      if (setupName && setupSlug) {
        setupName.addEventListener('input', () => {
          const val = setupName.value;
          const cleanSlug = val
            .toLowerCase()
            .trim()
            .replace(/[^\w\s-]/g, '')
            .replace(/[\s_]+/g, '-')
            .replace(/^-+|-+$/g, '');
          setupSlug.value = cleanSlug;
        });
      }

      // Setup tracker submit handler
      const setupForm = document.getElementById('setup-form');
      const setupSubmit = document.getElementById('btn-submit-setup');
      if (setupForm && setupSubmit) {
        setupForm.addEventListener('submit', async (e) => {
          e.preventDefault();

          const handles = {
            x: document.getElementById('handle-x').value.trim(),
            instagram: document.getElementById('handle-instagram').value.trim(),
            tiktok: document.getElementById('handle-tiktok').value.trim(),
            linkedin: document.getElementById('handle-linkedin').value.trim()
          };

          if (!handles.x && !handles.instagram && !handles.tiktok && !handles.linkedin) {
            alert('Please fill in at least one social media handle to track.');
            return;
          }

          const name = setupName.value.trim();
          const slug = setupSlug.value.trim() || 'my-presence';

          const originalContent = setupSubmit.innerHTML;
          setupSubmit.innerHTML = `
            <svg class="spinner" viewBox="0 0 50 50" style="width:18px; height:18px; animation:rotate 2s linear infinite; margin-right:8px; display:inline-block; vertical-align:middle;">
              <circle class="path" cx="25" cy="25" r="20" fill="none" stroke-width="5" stroke="#ffffff" stroke-linecap="round" style="stroke-dasharray:90,150; stroke-dashoffset:0;"></circle>
            </svg>
            <span>Analyzing Profiles & Initializing...</span>
          `;
          setupSubmit.setAttribute('disabled', 'true');

          try {
            // Save tracker to Cloudflare D1
            const res = await fetch('/api/trackers', {
              method: 'POST',
              headers: { 'Content-Type': 'application/json' },
              body: JSON.stringify({
                name,
                slug,
                x: handles.x,
                instagram: handles.instagram,
                tiktok: handles.tiktok,
                linkedin: handles.linkedin
              })
            });

            setupSubmit.innerHTML = originalContent;
            setupSubmit.removeAttribute('disabled');

            if (!res.ok) {
              const errData = await res.json();
              alert(errData.error || "Failed to save tracker. Slug might be taken.");
              return;
            }

            const history = generateSimulatedHistory(handles, slug);
            const trackerObj = {
              name,
              slug,
              x: handles.x,
              instagram: handles.instagram,
              tiktok: handles.tiktok,
              linkedin: handles.linkedin,
              history
            };

            // Back up to LocalStorage
            saveCustomTracker(trackerObj);

            // Fetch and render to grid
            await fetchAndRenderUserTrackers();

            const latest = history[history.length - 1];
            const previous = history[history.length - 2] || latest;
            const currentTotal = latest.aggregate;
            const dailyChange = latest.aggregate - previous.aggregate;

            document.getElementById('success-brand-name').textContent = name;
            document.getElementById('success-card-title').textContent = name;
            document.getElementById('success-card-handle').textContent = handles.x ? `@${handles.x}` : handles.instagram ? `@${handles.instagram}` : 'active tracking';
            document.getElementById('success-card-reach').textContent = currentTotal.toLocaleString();
            
            const growthBadge = document.getElementById('success-card-growth');
            growthBadge.textContent = (dailyChange >= 0 ? '+' : '') + dailyChange.toLocaleString();
            growthBadge.className = 'success-metric-change ' + (dailyChange >= 0 ? 'positive' : 'negative');

            const initials = name.split(' ').map(n => n[0]).join('').slice(0, 2).toUpperCase();
            document.getElementById('success-card-avatar-initials').textContent = initials;

            showStep(stepSuccess);

            document.getElementById('btn-view-custom-dashboard').onclick = () => {
              closeModal();
              openCustomDashboard(trackerObj);
            };
            
            document.getElementById('btn-close-success').onclick = () => {
              closeModal();
            };

          } catch (err) {
            setupSubmit.innerHTML = originalContent;
            setupSubmit.removeAttribute('disabled');
            console.error("Tracker save failed:", err);
            alert("Database connection error. Using local fallback.");
          }
        });
      }
    </script>
  </body>
</html>

