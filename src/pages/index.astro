---
import '../styles/global.css';
import customersData from '../data/customers.json';

// Slice to limit to the top 10 customers based on aggregate audience
const top10Customers = customersData.slice(0, 10);

// Page Title and Meta Description for SEO
const pageTitle = "Growth History — Top Tracked Social Media Audiences";
const pageDescription = "Explore the daily follower count history and audience growth metrics across Instagram, X, TikTok, and LinkedIn for top organizations. Powered by Growthcat.ai.";
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="viewport" content="width=device-width" />
    
    <!-- SEO Meta Tags -->
    <title>{pageTitle}</title>
    <meta name="description" content={pageDescription} />
    <meta name="robots" content="index, follow" />
    
    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content="https://growth-history.com/" />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={pageDescription} />
    <meta property="og:image" content="https://growth-history.com/og-image.png" />
    
    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={pageDescription} />
    
    <meta name="generator" content={Astro.generator} />
  </head>
  
  <body>
    <header class="app-header">
      <div class="header-container">
        <a href="/" class="brand-logo" id="logo-home-link">
          <svg viewBox="0 0 24 24" fill="none" stroke="url(#logoGradient)" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="logo-icon">
            <polyline points="22 12 18 12 15 21 9 3 6 12 2 12"></polyline>
            <defs>
              <linearGradient id="logoGradient" x1="0" y1="0" x2="1" y2="0">
                <stop offset="0%" stop-color="#8B5CF6" />
                <stop offset="100%" stop-color="#EC4899" />
              </linearGradient>
            </defs>
          </svg>
          <span class="logo-text">Growth<span class="gradient-text">History</span></span>
        </a>
        <div class="header-auth" id="header-auth-section"></div>
      </div>
    </header>

    <main class="main-content">
      <div class="intro-section">
        <h1>Audience Size Directory</h1>
        <p>Real-time network size intelligence. Browse and inspect the follower growth profiles of top creators and companies.</p>
      </div>

      <!-- Directory Card Grid -->
      <div class="directory-grid" id="customer-directory-grid">
        {top10Customers.map((customer, index) => {
          const formattedTotal = customer.currentTotal.toLocaleString();
          const formattedChange = customer.dailyChange >= 0 
            ? `+${customer.dailyChange.toLocaleString()}` 
            : customer.dailyChange.toLocaleString();
          const isPositive = customer.dailyChange >= 0;

          // Helper to get initials if logo doesn't exist
          const initials = customer.name.split(' ').map(n => n[0]).join('').slice(0, 2);

          return (
            <a href={`/${customer.slug}/`} class="customer-card glass-panel" id={`customer-card-${customer.slug}`}>
              <div class="card-ranking">#{index + 1}</div>
              
              <div class="customer-profile">
                {customer.logoUrl ? (
                  <img src={customer.logoUrl} alt={customer.name} class="customer-logo" />
                ) : (
                  <div class="customer-avatar" style={`background: linear-gradient(135deg, hsla(${index * 55}, 70%, 50%, 0.15) 0%, hsla(${index * 55 + 40}, 80%, 40%, 0.3) 100%)`}>
                    {initials}
                  </div>
                )}
                <div class="customer-identity">
                  <h3>{customer.name}</h3>
                  <span class="customer-handles-badge">
                    {customer.xHandle || customer.instagramHandle || 'Active Tracking'}
                  </span>
                </div>
              </div>

              <div class="audience-stats">
                <div class="metric-block">
                  <span class="metric-label">Total Reach</span>
                  <span class="metric-value">{formattedTotal}</span>
                </div>
                <div class="metric-block align-right">
                  <span class="metric-label">Daily Growth</span>
                  <span class={`metric-change ${isPositive ? 'positive' : 'negative'}`}>
                    {formattedChange}
                  </span>
                </div>
              </div>

              {/* Small platform breakdown visuals */}
              <div class="platform-bar-container">
                <span class="platform-bar-title">Breakdown</span>
                <div class="progress-bar-wrap">
                  {Object.entries(customer.platforms).map(([platform, count]) => {
                    const pct = (count / customer.currentTotal) * 100;
                    return (
                      <div 
                        class={`platform-segment segment-${platform}`} 
                        style={`width: ${pct}%`} 
                        title={`${platform.toUpperCase()}: ${count.toLocaleString()} (${pct.toFixed(0)}%)`}
                      />
                    );
                  })}
                </div>
              </div>

              {/* Click-through indicator */}
              <div class="card-action-indicator">
                <span>View Full Growth Graph</span>
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" class="arrow-icon">
                  <line x1="5" y1="12" x2="19" y2="12"></line>
                  <polyline points="12 5 19 12 12 19"></polyline>
                </svg>
              </div>
            </a>
          );
        })}
      </div>

      <!-- CTA Section -->
      <section class="cta-section glass-panel" id="cta-get-started-section">
        <div class="cta-glow"></div>
        <div class="cta-content">
          <h2 class="cta-title">Want to track your audience?</h2>
          <p class="cta-description">Monitor your cross-platform growth and download premium, shareable analytics growth cards. Sign up to customize your tracking index today.</p>
          <button class="btn-primary" id="btn-cta-get-started">
            <span>Click to Get Started</span>
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" class="btn-arrow-icon">
              <line x1="5" y1="12" x2="19" y2="12"></line>
              <polyline points="12 5 19 12 12 19"></polyline>
            </svg>
          </button>
        </div>
      </section>
    </main>

    <footer class="app-footer">
      <div class="footer-container">
        <p class="footer-copy">&copy; {new Date().getFullYear()} Growth History. All rights reserved.</p>
        <div class="footer-credit">
          <a href="https://growthcat.ai" class="follow-backlink" id="growthcat-backlink" target="_blank" rel="noopener">
            Powered by the <span class="credit-highlight">Growthcat.ai System</span>
          </a>
        </div>
      </div>
    </footer>

    <!-- Signup & Setup Modal -->
    <div id="tracking-modal" class="modal-backdrop hidden">
      <div class="modal-container glass-panel">
        <button id="modal-close-btn" class="modal-close-btn" aria-label="Close modal">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <line x1="18" y1="6" x2="6" y2="18"></line>
            <line x1="6" y1="6" x2="18" y2="18"></line>
          </svg>
        </button>

        <!-- STEP 1: SIGN UP -->
        <div id="modal-step-signup" class="modal-step active">
          <div class="modal-header">
            <h3 id="auth-modal-title">Create your account</h3>
            <p id="auth-modal-subtitle">Start tracking your brand's growth history across platforms.</p>
          </div>
          
          <div class="sso-options">
            <button class="btn-sso btn-google" id="btn-sso-google">
              <svg viewBox="0 0 24 24" width="18" height="18" class="sso-icon">
                <path fill="#4285F4" d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z"/>
                <path fill="#34A853" d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z"/>
                <path fill="#FBBC05" d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.06H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.94l2.85-2.22-.04-.63z"/>
                <path fill="#EA4335" d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.06l3.66 2.84c.87-2.6 3.3-4.52 6.16-4.52z"/>
              </svg>
              <span>Continue with Google</span>
            </button>
            <button class="btn-sso btn-facebook" id="btn-sso-facebook">
              <svg viewBox="0 0 24 24" width="18" height="18" class="sso-icon" fill="currentColor">
                <path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/>
              </svg>
              <span>Continue with Facebook</span>
            </button>
          </div>

          <div class="divider">
            <span id="auth-divider-text">or email signup</span>
          </div>

          <form id="signup-form" class="modal-form">
            <div class="form-group">
              <label for="signup-email">Email Address</label>
              <input type="email" id="signup-email" placeholder="you@example.com" required class="form-input" />
            </div>
            <div class="form-group">
              <label for="signup-password">Password</label>
              <input type="password" id="signup-password" placeholder="••••••••" required class="form-input" />
            </div>
            <button type="submit" class="btn-submit" id="btn-submit-signup">
              <span id="btn-submit-auth-text">Sign Up with Email</span>
            </button>
          </form>

          <div class="auth-toggle-link-container" style="margin-top: 16px; text-align: center;">
            <a href="#" id="link-toggle-auth-mode" style="color: var(--color-text-secondary); font-size: 0.85rem; text-decoration: none; font-weight: 500;">
              Already have an account? <span style="color: #8B5CF6; font-weight: 700;">Sign In</span>
            </a>
          </div>
        </div>

        <!-- STEP 2: SETUP TRACKER -->
        <div id="modal-step-setup" class="modal-step">
          <div class="modal-header">
            <h3>Set Up Tracking</h3>
            <p>Define your presence and enter social handles to start tracking.</p>
          </div>

          <form id="setup-form" class="modal-form">
            <div class="form-group">
              <label for="setup-name">Company or Online Presence Name</label>
              <input type="text" id="setup-name" placeholder="e.g. Ali Abdaal or Vercel" required class="form-input" />
            </div>
            
            <div class="form-group">
              <label for="setup-slug">Custom Slug</label>
              <div class="slug-input-wrapper">
                <span class="slug-prefix">growth-history.com/</span>
                <input type="text" id="setup-slug" placeholder="slug" required class="form-input slug-input" />
              </div>
              <span class="form-note">Your analytics page will be previewable at this address.</span>
            </div>

            <div class="form-divider">Social Profiles to Track</div>

            <div class="social-input-grid">
              <div class="form-group social-group x">
                <label for="handle-x">
                  <svg viewBox="0 0 24 24" class="inline-social-icon"><path fill="currentColor" d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
                  X / Twitter Handle
                </label>
                <input type="text" id="handle-x" placeholder="username" class="form-input" />
              </div>

              <div class="form-group social-group instagram">
                <label for="handle-instagram">
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" class="inline-social-icon"><rect x="2" y="2" width="20" height="20" rx="5" ry="5"></rect><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"></path><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"></line></svg>
                  Instagram Handle
                </label>
                <input type="text" id="handle-instagram" placeholder="username" class="form-input" />
              </div>

              <div class="form-group social-group tiktok">
                <label for="handle-tiktok">
                  <svg viewBox="0 0 24 24" fill="currentColor" class="inline-social-icon"><path d="M12.525.02c1.31-.02 2.61-.01 3.91-.02.08 1.53.63 3.09 1.75 4.17 1.12 1.11 2.7 1.62 4.24 1.79v4.03c-1.44-.17-2.86-.74-3.94-1.72-.49-.44-.9-.97-1.24-1.55v6.52c-.07 2.32-.93 4.67-2.68 6.13-1.8 1.56-4.4 2.15-6.69 1.56-2.26-.52-4.22-2.18-5.07-4.37-.97-2.4-.42-5.33 1.37-7.2 1.55-1.68 3.96-2.38 6.19-1.81V12.7c-1.22-.38-2.61-.08-3.55.77-.96.84-1.26 2.22-1.07 3.44.15 1.15.89 2.19 1.93 2.68 1.05.51 2.35.34 3.23-.42.79-.65 1.18-1.7 1.17-2.71L12.525.02z"/></svg>
                  TikTok Handle
                </label>
                <input type="text" id="handle-tiktok" placeholder="username" class="form-input" />
              </div>

              <div class="form-group social-group linkedin">
                <label for="handle-linkedin">
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" class="inline-social-icon"><path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"></path><rect x="2" y="9" width="4" height="12"></rect><circle cx="4" cy="4" r="2"></circle></svg>
                  LinkedIn ID
                </label>
                <input type="text" id="handle-linkedin" placeholder="company-id" class="form-input" />
              </div>
            </div>

            <button type="submit" class="btn-submit" id="btn-submit-setup">
              <span>Create Tracker</span>
            </button>
          </form>
        </div>

        <!-- STEP 3: SUCCESS & RETRIEVE -->
        <div id="modal-step-success" class="modal-step">
          <div class="success-animation">
            <svg class="checkmark" viewBox="0 0 52 52">
              <circle class="checkmark__circle" cx="26" cy="26" r="25" fill="none"/>
              <path class="checkmark__check" fill="none" d="M14.1 27.2l7.1 7.2 16.7-16.8"/>
            </svg>
          </div>

          <div class="modal-header text-center">
            <h3>Tracking Configured!</h3>
            <p>Your custom track <span id="success-brand-name" class="success-highlight">Vercel</span> is now ready.</p>
          </div>

          <div class="success-card glass-panel">
            <div class="success-card-ranking">My Tracker</div>
            <div class="success-card-profile">
              <div class="success-card-avatar" id="success-card-avatar-initials">VC</div>
              <div class="success-card-identity">
                <h4 id="success-card-title">Vercel</h4>
                <span id="success-card-handle" class="customer-handles-badge">vercel</span>
              </div>
            </div>
            <div class="success-card-stats">
              <div class="success-metric">
                <span class="metric-label">Initial Reach</span>
                <span class="metric-value" id="success-card-reach">1,240,000</span>
              </div>
              <div class="success-metric align-right">
                <span class="metric-label">Daily Growth</span>
                <span class="metric-change positive" id="success-card-growth">+2,400</span>
              </div>
            </div>
          </div>

          <div class="success-actions">
            <button class="btn-submit" id="btn-view-custom-dashboard">
              <span>View Live Dashboard</span>
            </button>
            <button class="btn-secondary" id="btn-close-success">
              <span>Back to Directory</span>
            </button>
          </div>
        </div>
      </div>
    </div>

    <!-- Client-side Custom Dashboard Overlay -->
    <div id="custom-dashboard-overlay" class="dashboard-overlay hidden">
      <header class="app-header">
        <div class="header-container">
          <a href="#" id="custom-dashboard-logo-link" class="brand-logo">
            <svg viewBox="0 0 24 24" fill="none" stroke="url(#logoGradient-dashboard)" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="logo-icon">
              <polyline points="22 12 18 12 15 21 9 3 6 12 2 12"></polyline>
              <defs>
                <linearGradient id="logoGradient-dashboard" x1="0" y1="0" x2="1" y2="0">
                  <stop offset="0%" stop-color="#8B5CF6" />
                  <stop offset="100%" stop-color="#EC4899" />
                </linearGradient>
              </defs>
            </svg>
            <span class="logo-text">Growth<span class="gradient-text">History</span></span>
          </a>
          
          <button id="custom-share-button" class="btn-share">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="btn-icon">
              <path d="M4 12v8a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2v-8"></path>
              <polyline points="16 6 12 2 8 6"></polyline>
              <line x1="12" y1="2" x2="12" y2="15"></line>
            </svg>
            <span id="custom-share-btn-text">Share Growth Card</span>
          </button>
        </div>
      </header>

      <main class="main-content">
        <div class="profile-header-section">
          <div class="back-navigation">
            <button id="btn-back-to-directory" class="btn-back">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" class="back-arrow-icon">
                <line x1="19" y1="12" x2="5" y2="12"></line>
                <polyline points="12 19 5 12 12 5"></polyline>
              </svg>
              Back to Directory
            </button>
          </div>
          
          <h1 class="profile-title" id="custom-dashboard-title">My Presence</h1>
          <p class="profile-subtitle">Live analytics dashboard for audience velocity and distribution</p>
        </div>

        <div id="custom-shareable-container" class="capture-wrapper">
          <!-- Watermark Header -->
          <div class="capture-watermark-header">
            <div class="watermark-brand">
              <svg viewBox="0 0 24 24" fill="none" stroke="url(#watermarkGrad-custom)" stroke-width="2.5" class="watermark-logo-icon">
                <polyline points="22 12 18 12 15 21 9 3 6 12 2 12"></polyline>
                <defs>
                  <linearGradient id="watermarkGrad-custom" x1="0" y1="0" x2="1" y2="0">
                    <stop offset="0%" stop-color="#8B5CF6" />
                    <stop offset="100%" stop-color="#EC4899" />
                  </linearGradient>
                </defs>
              </svg>
              <span>Growth<strong>History</strong></span>
            </div>
            <span class="watermark-domain" id="custom-watermark-domain">My Presence (growth-history.com/my-presence/)</span>
          </div>

          <!-- SVG Chart Area -->
          <div id="custom-chart-container-placeholder"></div>

          <!-- Platform Grid Area -->
          <div class="matrix-grid" id="custom-matrix-container-placeholder"></div>

          <!-- Watermark Footer -->
          <div class="capture-watermark-footer">
            <span class="watermark-phrase">Growth is not luck.</span>
            <span class="watermark-credit">Powered by the Growthcat.ai System</span>
          </div>
        </div>
      </main>
      
      <footer class="app-footer">
        <div class="footer-container">
          <p class="footer-copy">&copy; 2026 Growth History. All rights reserved.</p>
          <div class="footer-credit">
            <a href="https://growthcat.ai" class="follow-backlink" target="_blank" rel="noopener">
              Powered by the <span class="credit-highlight">Growthcat.ai System</span>
            </a>
          </div>
        </div>
      </footer>
    </div>

    <!-- Client-side Javascript Interactivity -->
    <script>
      import { authClient } from '../lib/auth-client';

      const LOCAL_STORAGE_KEY = 'customTracker_v1';
      let currentUser = null;

      // 1. Check User Session & Update Header and CTA
      async function checkSession() {
        try {
          const { data: sessionData } = await authClient.getSession();
          const authSection = document.getElementById('header-auth-section');
          if (!authSection) return;

          if (sessionData && sessionData.user) {
            currentUser = sessionData.user;
            const initials = currentUser.name ? currentUser.name.split(' ').map(n => n[0]).join('').slice(0, 2).toUpperCase() : 'U';
            authSection.innerHTML = `
              <div class="user-badge">
                <div class="user-avatar-small">${initials}</div>
                <span class="user-name-small">${currentUser.name || currentUser.email}</span>
              </div>
              <button class="btn-logout" id="btn-header-logout">Logout</button>
            `;

            // Bind logout
            document.getElementById('btn-header-logout').onclick = async () => {
              await authClient.signOut();
              window.location.reload();
            };

            // Upgrade Bottom CTA card to "Add Custom Tracker"
            const ctaPanel = document.getElementById('cta-get-started-section');
            if (ctaPanel) {
              ctaPanel.querySelector('.cta-title').textContent = "Track another presence?";
              ctaPanel.querySelector('.cta-description').textContent = "Add another custom online presence or organization index tracker to your directory.";
              ctaPanel.querySelector('#btn-cta-get-started span').textContent = "Add Custom Tracker";
            }

            // Sync from Database
            await fetchAndRenderUserTrackers();
          } else {
            currentUser = null;
            authSection.innerHTML = `
              <button class="btn-header-login" id="btn-header-login">Login</button>
            `;
            document.getElementById('btn-header-login').onclick = () => {
              const modal = document.getElementById('tracking-modal');
              if (modal) {
                modal.classList.remove('hidden');
                showStep(stepSignup);
              }
            };

            // Render local storage trackers if logged out
            const localTracker = getCustomTracker();
            if (localTracker) {
              renderCustomCard(localTracker);
            }
          }
        } catch (e) {
          console.error("Failed to verify session:", e);
        }
      }

      function getCustomTracker() {
        try {
          const val = localStorage.getItem(LOCAL_STORAGE_KEY);
          return val ? JSON.parse(val) : null;
        } catch (e) {
          console.error('Failed to parse custom tracker', e);
          return null;
        }
      }

      function saveCustomTracker(tracker) {
        try {
          localStorage.setItem(LOCAL_STORAGE_KEY, JSON.stringify(tracker));
        } catch (e) {
          console.error('Failed to save custom tracker', e);
        }
      }

      // Sync and render trackers from Cloudflare D1
      async function fetchAndRenderUserTrackers() {
        try {
          const res = await fetch('/api/trackers');
          if (res.status === 418) return; // Not logged in
          if (!res.ok) return;
          const data = await res.json();
          
          if (data.trackers && data.trackers.length > 0) {
            // Remove any old local-storage/custom cards to prevent duplication
            document.querySelectorAll('.custom-user-card').forEach(el => el.remove());

            data.trackers.forEach(tracker => {
              const handles = {
                x: tracker.xHandle,
                instagram: tracker.instagramHandle,
                tiktok: tracker.tiktokHandle,
                linkedin: tracker.linkedinId
              };
              const history = generateSimulatedHistory(handles, tracker.slug);
              const fullTracker = {
                name: tracker.name,
                slug: tracker.slug,
                x: tracker.xHandle,
                instagram: tracker.instagramHandle,
                tiktok: tracker.tiktokHandle,
                linkedin: tracker.linkedinId,
                history
              };
              renderCustomCard(fullTracker);
            });
          }
        } catch (e) {
