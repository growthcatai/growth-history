      function generateClientSVG(history, width = 1000, height = 400, padding = { top: 40, right: 40, bottom: 60, left: 85 }) {
        const plotWidth = width - padding.left - padding.right;
        const plotHeight = height - padding.top - padding.bottom;
        
        const aggregates = history.map(h => h.aggregate);
        const maxAggregate = Math.max(...aggregates);
        const minAggregate = Math.min(...aggregates);
        
        const range = maxAggregate - minAggregate;
        const yBuffer = range * 0.1 || 10000;
        const yMax = maxAggregate + yBuffer;
        const yMin = Math.max(0, minAggregate - yBuffer);
        
        const points = history.map((item, index) => {
          const x = padding.left + (index / (history.length - 1)) * plotWidth;
          const y = padding.top + plotHeight - ((item.aggregate - yMin) / (yMax - yMin)) * plotHeight;
          return { x, y, item, index };
        });
        
        const linePath = points.map((p, i) => `${i === 0 ? 'M' : 'L'} ${p.x.toFixed(1)} ${p.y.toFixed(1)}`).join(' ');
        const fillPath = `${linePath} L ${points[points.length - 1].x.toFixed(1)} ${(padding.top + plotHeight).toFixed(1)} L ${points[0].x.toFixed(1)} ${(padding.top + plotHeight).toFixed(1)} Z`;
        
        const xLabelCount = 5;
        const xLabelIndices = Array.from({ length: xLabelCount }, (_, i) => 
          Math.min(Math.floor((i / (xLabelCount - 1)) * (history.length - 1)), history.length - 1)
        );
        
        const yLabelCount = 5;
        const yLabels = Array.from({ length: yLabelCount }, (_, i) => {
          const value = yMin + (i / (yLabelCount - 1)) * (yMax - yMin);
          const y = padding.top + plotHeight - (i / (yLabelCount - 1)) * plotHeight;
          return { value, y };
        });
        
        function formatBigNumber(num) {
          if (num >= 1000000) return (num / 1000000).toFixed(2).replace(/\.00$/, '') + 'M';
          if (num >= 1000) return (num / 1000).toFixed(1).replace(/\.0$/, '') + 'K';
          return num.toString();
        }
        
        function formatLabelDate(dateStr) {
          const d = new Date(dateStr + 'T00:00:00');
          return d.toLocaleDateString('en-US', { month: 'short', day: 'numeric' });
        }

        let yAxisHtml = '';
        yLabels.forEach(label => {
          yAxisHtml += `
            <g class="grid-group">
              <line x1="${padding.left}" y1="${label.y}" x2="${width - padding.right}" y2="${label.y}" class="grid-line" />
              <text x="${padding.left - 15}" y="${label.y + 4}" class="axis-text y-axis-text">${formatBigNumber(label.value)}</text>
            </g>
          `;
        });

        let xAxisHtml = '';
        xLabelIndices.forEach(idx => {
          const p = points[idx];
          xAxisHtml += `
            <g class="grid-group">
              <line x1="${p.x}" y1="${padding.top}" x2="${p.x}" y2="${padding.top + plotHeight}" class="grid-line" />
              <text x="${p.x}" y="${padding.top + plotHeight + 25}" class="axis-text x-axis-text">${formatLabelDate(p.item.date)}</text>
            </g>
          `;
        });

        let triggersHtml = '';
        points.forEach(p => {
          let tooltipOffsetX = 0;
          if (p.index < 5) tooltipOffsetX = 25;
          else if (p.index > history.length - 6) tooltipOffsetX = -25;
          
          triggersHtml += `
            <g class="point-trigger">
              <line x1="${p.x}" y1="${padding.top}" x2="${p.x}" y2="${padding.top + plotHeight}" class="hover-line" />
              <circle cx="${p.x}" cy="${p.y}" r="8" class="hover-glow-dot" />
              <circle cx="${p.x}" cy="${p.y}" r="3.5" class="hover-dot" />
              <g class="tooltip" style="transform: translate(${p.x + tooltipOffsetX}px, ${p.y - 12}px)">
                <rect x="-60" y="-62" width="120" height="52" rx="10" class="tooltip-bg" />
                <text y="-44" class="tooltip-date">${formatLabelDate(p.item.date)}</text>
                <text y="-22" class="tooltip-value">${p.item.aggregate.toLocaleString()}</text>
                <path d="M -6 -10 L 0 -4 L 6 -10 Z" class="tooltip-arrow" style="transform: translateX(${-tooltipOffsetX}px)" />
              </g>
              <rect x="${p.x - (plotWidth / history.length) / 2}" y="${padding.top}" width="${plotWidth / history.length}" height="${plotHeight}" class="trigger-rect" />
            </g>
          `;
        });

        return `
          <div class="chart-container glass-panel" id="main-chart-card">
            <div class="chart-header">
              <div class="chart-title-area">
                <h3>Total Audience Size</h3>
              </div>
              <div class="total-followers-display">
                <span class="total-followers-count">${history[history.length - 1].aggregate.toLocaleString()}</span>
                <span class="total-followers-label">Followers</span>
              </div>
            </div>

            <div class="svg-wrapper">
              <svg viewBox="0 0 ${width} ${height}" width="100%" height="100%" class="growth-svg" preserveAspectRatio="xMidYMid meet">
                <defs>
                  <radialGradient id="bgGlow-client" cx="50%" cy="40%" r="50%">
                    <stop offset="0%" stop-color="rgba(139, 92, 246, 0.15)" />
                    <stop offset="100%" stop-color="rgba(3, 0, 20, 0)" />
                  </radialGradient>
                  <linearGradient id="areaGradient-client" x1="0" y1="0" x2="0" y2="1">
                    <stop offset="0%" stop-color="rgba(236, 72, 153, 0.25)" />
                    <stop offset="50%" stop-color="rgba(139, 92, 246, 0.1)" />
                    <stop offset="100%" stop-color="rgba(139, 92, 246, 0)" />
                  </linearGradient>
                  <linearGradient id="lineGradient-client" x1="0" y1="0" x2="1" y2="0">
                    <stop offset="0%" stop-color="#3B82F6" />
                    <stop offset="35%" stop-color="#8B5CF6" />
                    <stop offset="100%" stop-color="#EC4899" />
                  </linearGradient>
                  <filter id="glow-client" x="-20%" y="-20%" width="140%" height="140%">
                    <feGaussianBlur stdDeviation="6" result="blur" />
                    <feMerge>
                      <feMergeNode in="blur" />
                      <feMergeNode in="SourceGraphic" />
                    </feMerge>
                  </filter>
                </defs>
                <rect x="${padding.left}" y="${padding.top}" width="${plotWidth}" height="${plotHeight}" fill="url(#bgGlow-client)" />
                ${yAxisHtml}
                ${xAxisHtml}
                <path d="${fillPath}" fill="url(#areaGradient-client)" />
                <path d="${linePath}" fill="none" stroke="url(#lineGradient-client)" stroke-width="8" stroke-linecap="round" opacity="0.3" filter="url(#glow-client)" />
                <path d="${linePath}" fill="none" stroke="url(#lineGradient-client)" stroke-width="4.5" stroke-linecap="round" stroke-linejoin="round" />
                <g class="interactive-triggers">${triggersHtml}</g>
              </svg>
            </div>
          </div>
        `;
      }

      function generateClientBreakdownMatrix(history) {
        const current = history[history.length - 1];
        const previous = history[history.length - 2] || current;

        const platformsInfo = [
          {
            name: 'Instagram',
            key: 'instagram',
            current: current.instagram,
            previous: previous.instagram,
            colorClass: 'instagram',
            gradient: 'var(--grad-instagram)',
            icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="social-icon"><rect x="2" y="2" width="20" height="20" rx="5" ry="5"></rect><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"></path><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"></line></svg>`
          },
          {
            name: 'X',
            key: 'x',
            current: current.x,
            previous: previous.x,
            colorClass: 'x',
            gradient: 'var(--grad-x)',
            icon: `<svg viewBox="0 0 24 24" fill="currentColor" class="social-icon"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>`
          },
          {
            name: 'TikTok',
            key: 'tiktok',
            current: current.tiktok,
            previous: previous.tiktok,
            colorClass: 'tiktok',
            gradient: 'var(--grad-tiktok)',
            icon: `<svg viewBox="0 0 24 24" fill="currentColor" class="social-icon"><path d="M12.525.02c1.31-.02 2.61-.01 3.91-.02.08 1.53.63 3.09 1.75 4.17 1.12 1.11 2.7 1.62 4.24 1.79v4.03c-1.44-.17-2.86-.74-3.94-1.72-.49-.44-.9-.97-1.24-1.55v6.52c-.07 2.32-.93 4.67-2.68 6.13-1.8 1.56-4.4 2.15-6.69 1.56-2.26-.52-4.22-2.18-5.07-4.37-.97-2.4-.42-5.33 1.37-7.2 1.55-1.68 3.96-2.38 6.19-1.81V12.7c-1.22-.38-2.61-.08-3.55.77-.96.84-1.26 2.22-1.07 3.44.15 1.15.89 2.19 1.93 2.68 1.05.51 2.35.34 3.23-.42.79-.65 1.18-1.7 1.17-2.71L12.525.02z"/></svg>`
          },
          {
            name: 'LinkedIn',
            key: 'linkedin',
            current: current.linkedin,
            previous: previous.linkedin,
            colorClass: 'linkedin',
            gradient: 'var(--grad-linkedin)',
            icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="social-icon"><path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"></path><rect x="2" y="9" width="4" height="12"></rect><circle cx="4" cy="4" r="2"></circle></svg>`
          }
        ];

        let matrixHtml = '';
        platformsInfo.forEach(stat => {
          if (stat.current === 0) return;

          const diff = stat.current - stat.previous;
          const pct = stat.previous > 0 ? (diff / stat.previous) * 100 : 0;
          const diffFormatted = diff >= 0 ? `+${diff.toLocaleString()}` : diff.toLocaleString();
          const pctFormatted = diff >= 0 ? `+${pct.toFixed(2)}%` : `${pct.toFixed(2)}%`;
          const currentFormatted = stat.current.toLocaleString();
          const isPositive = diff >= 0;

          const trendIconSvg = isPositive
            ? `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" class="trend-icon"><polyline points="23 6 13.5 15.5 8.5 10.5 1 18"></polyline><polyline points="17 6 23 6 23 12"></polyline></svg>`
            : `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" class="trend-icon"><polyline points="23 18 13.5 8.5 8.5 13.5 1 6"></polyline><polyline points="17 18 23 18 23 12"></polyline></svg>`;

          matrixHtml += `
            <div class="stat-card glass-panel" style="--accent-color: var(--color-${stat.colorClass})">
              <div class="card-header">
                <div class="icon-box" style="background: ${stat.gradient}">
                  ${stat.icon}
                </div>
                <span class="network-name">${stat.name}</span>
              </div>
              
              <div class="card-body">
                <h4 class="stat-value">${currentFormatted}</h4>
                <div class="change-group">
                  <span class="change-badge ${isPositive ? 'positive' : 'negative'}">
                    ${trendIconSvg}
                    ${diffFormatted}
                  </span>
                  <span class="pct-label ${isPositive ? 'positive' : 'negative'}">${pctFormatted} today</span>
                </div>
              </div>
            </div>
          `;
        });

        return matrixHtml;
      }

      function openCustomDashboard(tracker) {
        const overlay = document.getElementById('custom-dashboard-overlay');
        const title = document.getElementById('custom-dashboard-title');
        const watermarkDomain = document.getElementById('custom-watermark-domain');
        
        if (!overlay || !title || !watermarkDomain) return;

        title.textContent = tracker.name;
        watermarkDomain.textContent = `${tracker.name} (growth-history.com/${tracker.slug}/)`;

        const chartPlaceholder = document.getElementById('custom-chart-container-placeholder');
        if (chartPlaceholder) {
          chartPlaceholder.innerHTML = generateClientSVG(tracker.history);
        }

        const matrixPlaceholder = document.getElementById('custom-matrix-container-placeholder');
        if (matrixPlaceholder) {
          matrixPlaceholder.innerHTML = generateClientBreakdownMatrix(tracker.history);
        }

        const btnBack = document.getElementById('btn-back-to-directory');
        if (btnBack) {
          btnBack.onclick = () => {
            overlay.classList.add('hidden');
            const url = new URL(window.location);
            url.searchParams.delete('preview');
            window.history.pushState({}, '', url);
          };
        }

        const logoLink = document.getElementById('custom-dashboard-logo-link');
        if (logoLink) {
          logoLink.onclick = (e) => {
            e.preventDefault();
            overlay.classList.add('hidden');
            const url = new URL(window.location);
            url.searchParams.delete('preview');
            window.history.pushState({}, '', url);
          };
        }

        const shareBtn = document.getElementById('custom-share-button');
        if (shareBtn) {
          const newShareBtn = shareBtn.cloneNode(true);
          shareBtn.parentNode.replaceChild(newShareBtn, shareBtn);
          
          const newBtnText = newShareBtn.querySelector('#custom-share-btn-text');

          newShareBtn.addEventListener('click', async () => {
            const target = document.getElementById('custom-shareable-container');
            if (!target) return;

            newShareBtn.classList.add('loading');
            newBtnText.textContent = 'Generating Image...';
            newShareBtn.setAttribute('disabled', 'true');

            try {
              const { default: html2canvas } = await import('html2canvas');
              target.classList.add('capturing');
              await new Promise(resolve => setTimeout(resolve, 150));

              const canvas = await html2canvas(target, {
                backgroundColor: '#030014',
                scale: 2,
                useCORS: true,
                logging: false,
                ignoreElements: (element) => {
                  return element.classList.contains('interactive-triggers') || 
                         element.classList.contains('btn-share');
                }
              });

              const dataUrl = canvas.toDataURL('image/png');
              const link = document.createElement('a');
              link.download = `growth-history-${tracker.slug}-${new Date().toISOString().split('T')[0]}.png`;
              link.href = dataUrl;
              document.body.appendChild(link);
              link.click();
              document.body.removeChild(link);

              newBtnText.textContent = 'Downloaded!';
              newShareBtn.classList.remove('loading');
              newShareBtn.classList.add('success');
            } catch (err) {
              console.error('Error generating growth history image:', err);
              newBtnText.textContent = 'Share Failed';
              newShareBtn.classList.remove('loading');
              newShareBtn.classList.add('error');
            } finally {
              target.classList.remove('capturing');
              setTimeout(() => {
                newShareBtn.removeAttribute('disabled');
                newShareBtn.classList.remove('success', 'error');
                newBtnText.textContent = 'Share Growth Card';
              }, 2500);
            }
          });
        }

        overlay.classList.remove('hidden');

        const url = new URL(window.location);
        url.searchParams.set('preview', tracker.slug);
        window.history.pushState({}, '', url);
      }

      const modal = document.getElementById('tracking-modal');
      const ctaBtn = document.getElementById('btn-cta-get-started');
      const closeBtn = document.getElementById('modal-close-btn');

      const stepSignup = document.getElementById('modal-step-signup');
      const stepSetup = document.getElementById('modal-step-setup');
