        [stepSignup, stepSetup, stepSuccess].forEach(s => s.classList.remove('active'));
        stepElement.classList.add('active');
      }

      if (ctaBtn && modal) {
        ctaBtn.addEventListener('click', () => {
          modal.classList.remove('hidden');
