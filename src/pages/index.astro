      function generateSimulatedHistory(handles, slug = 'default') {
        const history = [];
        const platforms = ['x', 'instagram', 'tiktok', 'linkedin'];
        
        function hashCode(str) {
          let hash = 0;
          for (let i = 0; i < str.length; i++) {
            hash = str.charCodeAt(i) + ((hash << 5) - hash);
          }
          return Math.abs(hash);
        }

        const seed = hashCode(slug);
        const random = (offset) => {
          const x = Math.sin(seed + offset) * 10000;
          return x - Math.floor(x);
        };

        const baseValues = {
          x: handles.x ? Math.floor(random(1) * 240000) + 10000 : 0,
          instagram: handles.instagram ? Math.floor(random(2) * 385000) + 15000 : 0,
          tiktok: handles.tiktok ? Math.floor(random(3) * 480000) + 20000 : 0,
          linkedin: handles.linkedin ? Math.floor(random(4) * 145000) + 5000 : 0
        };
        
        const dailyDeltas = {
          x: handles.x ? Math.floor(random(5) * 750) + 50 : 0,
          instagram: handles.instagram ? Math.floor(random(6) * 1400) + 100 : 0,
          tiktok: handles.tiktok ? Math.floor(random(7) * 2350) + 150 : 0,
          linkedin: handles.linkedin ? Math.floor(random(8) * 380) + 20 : 0
        };

        for (let i = 14; i >= 0; i--) {
          const d = new Date();
          d.setDate(d.getDate() - i);
          const dateStr = d.toISOString().split('T')[0];
          
          const dailyValues = {};
          let dailyAggregate = 0;
          
          platforms.forEach((platform, pIdx) => {
            if (baseValues[platform] > 0) {
              const dayOffset = 14 - i;
              const noise = Math.floor((random(9 + dayOffset + pIdx) - 0.5) * (dailyDeltas[platform] * 0.3));
              const val = baseValues[platform] + (dailyDeltas[platform] * dayOffset) + noise;
              dailyValues[platform] = Math.max(0, val);
              dailyAggregate += dailyValues[platform];
            } else {
              dailyValues[platform] = 0;
            }
          });

          history.push({
            date: dateStr,
            instagram: dailyValues.instagram,
            x: dailyValues.x,
            tiktok: dailyValues.tiktok,
            linkedin: dailyValues.linkedin,
            aggregate: dailyAggregate
          });
        }
        
        return history;
      }

